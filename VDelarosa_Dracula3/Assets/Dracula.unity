      objectReference: {fileID: 0}
    - target: {fileID: 4595234444170574, guid: 8b4e2585213011e43ab04d70f15e3a8a, type: 3}
      propertyPath: m_LocalEulerAnglesHint.y
      value: 14.998
      objectReference: {fileID: 0}
    - target: {fileID: 4595234444170574, guid: 8b4e2585213011e43ab04d70f15e3a8a, type: 3}
